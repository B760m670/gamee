# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*

# Lockfiles are intentionally not committed (CI uses `npm install
# --legacy-peer-deps`, not `npm ci`; the RN/Expo peer-dep graph makes a
# committed lockfile fragile).
package-lock.json
yarn.lock

# Environment / secrets
.env
.env.local
.env.*.local
*.local
*.pem
*.key
*.keystore
*.jks

# Expo / React Native
.expo/
dist/
web-build/
*.orig.*

# Native build output
*.apk
*.aab
*.ipa

# Note: this is a bare React Native app — the android/ and ios/ native
# projects ARE committed. Only their build/ output is ignored (see
# apps/mobile/.gitignore).

# Go
bin/
*.test

# Rust (future native core)
target/

# Logs
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Editor / OS
.DS_Store
.vscode/
.idea/

# Gradle / Kotlin Android app
.gradle/
apps/android/local.properties
apps/android/**/build/
*.hprof

# packages/crypto-core-ffi build output copied in by CI: the compiled
# native library and the UniFFI-generated Kotlin/Swift bindings are build
# artifacts, not source — regenerated by the CI workflows on every build.
# The rest of apps/mobile/ios/modules/spiritchat-crypto-core/ (the podspec,
# the Expo module wrapper, the JS entry point) is hand-written and stays committed.
apps/android/app/src/main/jniLibs/
apps/android/app/src/main/java/uniffi/
apps/mobile/ios/modules/spiritchat-crypto-core/ios/spiritchat_crypto_core_ffi.swift
apps/mobile/ios/modules/spiritchat-crypto-core/ios/spiritchat_crypto_core_ffiFFI.h
apps/mobile/ios/modules/spiritchat-crypto-core/ios/SpiritchatCryptoCoreFFI.xcframework/

# Keep the shared dev signing key (committed on purpose for sideload updates)
!apps/android/app/spiritchat.keystore

# Codespaces: generated Expo Go URL banner
OPEN-IN-EXPO-GO.txt
